MOCK_AI_ENABLED=false
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=
OPENAI_TIMEOUT_SECONDS=60
OPENAI_MAX_RETRIES=2
MAX_BATCH_CHARS=8000
