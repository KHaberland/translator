JOB_TTL_SECONDS=86400
TRANSLATION_CACHE_TTL_SECONDS=2592000
PROGRESS_STREAM_MAX_EVENTS=200
TRANSLATION_MEMORY_DB_PATH=data/translation_memory.sqlite3
